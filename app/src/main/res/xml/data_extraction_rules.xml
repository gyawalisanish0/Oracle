<?xml version="1.0" encoding="utf-8"?>
<!--
  Privacy-first: Domain AI opts out of cloud backup and device-transfer for all
  app data. Conversations are encrypted on-device and never leave it via the
  Android backup framework.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
